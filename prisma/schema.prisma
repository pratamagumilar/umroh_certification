generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("PESERTA") // ADMIN, PENGAWAS, PANITIA, PESERTA
  phone     String?
  photoUrl    String?
  kodePeserta String?   @unique
  isActive    Boolean   @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances            Attendance[]
  examResults            ExamResult[]
  certificates           Certificate[]
  examAnswers            ExamAnswer[]
  examSupervisors        ExamSupervisor[]

  // MVP 2 Learning Course Relations
  courseEnrollments     CourseEnrollment[]
  sessionProgresses     SessionProgress[]
  assignmentSubmissions AssignmentSubmission[]
  assignmentGrades      AssignmentGrade[]
  gradeAdjustments      GradeAdjustment[]
  createdMaterials      Material[]
  createdAssignments    MasterAssignment[]
  createdCourses        Course[]          @relation("CourseCreator")
  gradeAdjustmentsMade  GradeAdjustment[] @relation("GradeAdmin")

  // MVP 4 Registration
  pendaftaran           Pendaftaran?  @relation("PendaftaranUser")
  approvedRegistrations Pendaftaran[] @relation("PendaftaranApprover")

  // MVP 4 Absensi
  createdAbsensiEvents AbsensiEvent[]
  absensiRecords       AbsensiRecord[]

  @@index([role])
  @@index([isActive])
  @@index([role, isActive])
  @@index([kodePeserta])
}

model Exam {
  id              String   @id @default(uuid())
  title           String
  description     String?
  startTime       DateTime
  durationMinutes Int
  passingGrade    Float    @default(70)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendances  Attendance[]
  examResults  ExamResult[]
  certificates Certificate[]
  supervisors  ExamSupervisor[]
  questions    ExamQuestion[]

  // MVP 2 Learning Course Relations
  courseExams CourseExam[]

  @@index([isActive])
  @@index([startTime])
}

model ExamSupervisor {
  id        String   @id @default(uuid())
  userId    String
  examId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
}

model QuestionBank {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions Question[]
}

model Question {
  id            String   @id @default(uuid())
  bankId        String
  type          String   // PG, ESSAY
  text          String
  options       String?  // JSON string untuk Pilihan Ganda (A, B, C, D)
  correctAnswer String?  // Jawaban benar untuk PG
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bank        QuestionBank   @relation(fields: [bankId], references: [id], onDelete: Cascade)
  examAnswers ExamAnswer[]
  exams       ExamQuestion[]
}

model ExamQuestion {
  id         String   @id @default(uuid())
  examId     String
  questionId String

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
}

model ExamAnswer {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  answer     String
  score      Float?   // Nilai otomatis untuk PG, manual untuk Esai
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([score])
  @@index([userId, questionId])
}

model Attendance {
  id       String   @id @default(uuid())
  userId   String
  examId   String
  scanTime DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
}

model ExamResult {
  id          String   @id @default(uuid())
  userId      String
  examId      String
  pgScore     Float    @default(0)
  essayScore  Float    @default(0)
  finalStatus String   @default("PENDING") // PENDING, LULUS, TIDAK_LULUS
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@index([finalStatus])
  @@index([userId, examId])
}

model Certificate {
  id        String   @id @default(uuid())
  userId    String
  examId    String
  pdfUrl    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@index([userId])
}

// ============================================
// MVP 2: Learning Course Models
// ============================================

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator           User?              @relation("CourseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  enrollments       CourseEnrollment[]
  sessions          CourseSession[]
  courseExams       CourseExam[]
  gradeAdjustments  GradeAdjustment[]

  @@index([isActive])
}

model CourseEnrollment {
  id         String   @id @default(uuid())
  courseId   String
  userId     String
  status     String   @default("ENROLLED") // ENROLLED, COMPLETED, DROPPED
  enrolledAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([status])
  @@index([userId, courseId])
}

model CourseSession {
  id                 String   @id @default(uuid())
  courseId           String
  materialId         String?
  masterAssignmentId String?
  order              Int      @default(0)
  isActive           Boolean  @default(true)
  isLocked           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  course           Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  material         Material?         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  masterAssignment MasterAssignment? @relation(fields: [masterAssignmentId], references: [id], onDelete: Cascade)

  progresses  SessionProgress[]
  submissions AssignmentSubmission[]
}

model MasterAssignment {
  id          String   @id @default(uuid())
  title       String
  description String?  // Deskripsi atau instruksi untuk peserta
  prompt      String
  maxScore    Float    @default(100)
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy      User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  courseSessions CourseSession[]
}

model Material {
  id          String   @id @default(uuid())
  title       String
  description String?
  pdfUrl      String
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy      User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  courseSessions CourseSession[]
}

model SessionProgress {
  id          String   @id @default(uuid())
  sessionId   String
  userId      String
  status      String   @default("COMPLETED") // COMPLETED
  completedAt DateTime @default(now())

  session CourseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId])
}

model AssignmentSubmission {
  id          String   @id @default(uuid())
  sessionId   String
  userId      String
  answer      String
  status      String   @default("SUBMITTED") // DRAFT, SUBMITTED, GRADED, REVISION
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session CourseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  grades  AssignmentGrade[]

  @@unique([sessionId, userId])
  @@index([status])
  @@index([userId])
}

model AssignmentGrade {
  id           String   @id @default(uuid())
  submissionId String
  graderId     String
  score        Float
  feedback     String?
  gradedAt     DateTime @default(now())

  submission AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  grader     User                 @relation(fields: [graderId], references: [id], onDelete: Cascade)

  @@unique([submissionId])
}

model CourseExam {
  id         String  @id @default(uuid())
  courseId   String
  examId     String
  isRequired Boolean @default(true)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([courseId, examId])
}

model GradeAdjustment {
  id            String   @id @default(uuid())
  userId        String
  courseId      String
  adminId       String
  originalScore Float
  adjustedScore Float
  reason        String
  createdAt     DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  admin  User   @relation("GradeAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
}

// ============================================
// MVP 4: Registration Models
// ============================================

// ============================================
// MVP 4: Absensi Models
// ============================================

model AbsensiEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  kodeAbsen   String   @unique  // e.g. ABS-H1-001
  createdById String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  attendances AbsensiRecord[]

  @@index([kodeAbsen])
  @@index([createdById])
}

model AbsensiRecord {
  id       String   @id @default(uuid())
  eventId  String
  userId   String
  method   String   @default("QR_SCAN") // QR_SCAN, MANUAL, ADMIN
  scanTime DateTime @default(now())

  event AbsensiEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
}

enum TipeDokumen {
  PHOTO_3X4
  IJAZAH
  KTP
  KARTU_KELUARGA
  PASPOR
  VISA
  SURAT_SEHAT
  SURAT_PERNYATAAN
  BUKTI_TRANSFER
}

model Pendaftaran {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String

  // Step 2: Data Diri
  namaGelar       String
  namaTanpaGelar  String
  tempatLahir     String
  tanggalLahir    DateTime
  nik             String
  jenisKelamin    String
  noHp            String
  alamatTinggal   String
  provinsi        String

  // Step 3: Data Kerja
  unitKerja       String
  jabatan         String
  alamatKantor    String

  // Step 4: Pendidikan
  pendidikanTerakhir String
  namaUniversitas    String

  // Step 5: Perlengkapan
  ukuranBaju      String

  // Status
  status          String    @default("PENDING")
  alasanReject    String?
  approvedById    String?
  approvedAt      DateTime?

  userId          String?   @unique

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  approvedBy      User?              @relation("PendaftaranApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  user            User?              @relation("PendaftaranUser", fields: [userId], references: [id], onDelete: SetNull)
  dokumen         DokumenPendaftaran[]

  @@index([status])
  @@index([email])
}

model DokumenPendaftaran {
  id             String       @id @default(uuid())
  pendaftaranId  String
  tipeDokumen    TipeDokumen
  fileUrl        String
  namaAsli       String
  mimeType       String
  createdAt      DateTime     @default(now())

  pendaftaran    Pendaftaran  @relation(fields: [pendaftaranId], references: [id], onDelete: Cascade)

  @@unique([pendaftaranId, tipeDokumen])
  @@index([pendaftaranId])
}