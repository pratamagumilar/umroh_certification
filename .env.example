# =============================================================
# Environment Variables — Umroh Certification App
# Copy file ini menjadi .env dan isi nilainya.
# JANGAN commit file .env yang berisi secret ke Git.
# =============================================================

# --- Database (Supabase PostgreSQL) ---

# Runtime connection — WAJIB pakai port 6543 (pgBouncer transaction mode).
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=15&pool_timeout=20
# connection_limit: sesuaikan dengan plan Supabase (Free=15, Pro=50, Team=90)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=15&pool_timeout=20"

# Direct connection untuk Prisma migrate / introspection (session mode, port 5432).
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# --- NextAuth ---

# Harus diisi dengan nilai random yang kuat. Generate dengan:
#   openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-secret-yang-kuat"

# URL aplikasi. Untuk lokal: http://localhost:3000
# Untuk production: https://domain-anda.com
NEXTAUTH_URL="http://localhost:3000"

# --- File Storage (Development vs Production) ---

# STORAGE_DIR: Folder fisik tempat menyimpan upload PDF materi
# Local development: "./storage"
# Production aaPanel: "/www/wwwroot/umroh-certification-storage"
STORAGE_DIR="./storage"

# FILE_BASE_PATH: URL endpoint untuk akses/streaming file PDF
FILE_BASE_PATH="/api/files"

# MAX_UPLOAD_MB: Batas maksimal ukuran upload PDF dalam Megabyte
MAX_UPLOAD_MB="20"
